[storage]
# Path where tweets will be saved
# Can be absolute or relative
base_path = ./saved_tweets
create_date_folders = true

[download]
max_retries = 3
timeout_seconds = 30

[scraper]
use_playwright = true
headless = true
# Set to true to save debug screenshots on errors
debug_mode = false

[ai]
# Optional: Gemini API key for AI-powered tag generation
# Get yours at https://aistudio.google.com/
# gemini_api_key = YOUR_GEMINI_API_KEY_HERE

# Optional: Claude API key (alternative to Gemini)
# Get yours at https://console.anthropic.com/
# claude_api_key = YOUR_CLAUDE_API_KEY_HERE

[telegram]
# Optional: Telegram bot token for receiving tweet URLs via Telegram
# Create a bot at https://t.me/BotFather and paste the token here
# bot_token = YOUR_TELEGRAM_BOT_TOKEN_HERE
